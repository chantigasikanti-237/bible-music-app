NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/bible_app
JWT_SECRET=replace_with_a_32_plus_character_secret
JWT_ISSUER=bible-backend
JWT_AUDIENCE=bible-app
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
PASSWORD_RESET_TTL_MINUTES=15
BCRYPT_SALT_ROUNDS=12
REDIS_URL=
CORS_ORIGIN=http://localhost:3000
AUTH_COOKIE_NAME=refresh_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/api/auth
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=strict
TRUST_PROXY=false
EXPOSE_DEBUG_TOKENS=false
MFA_ISSUER=Bible App
YOUVERSION_APP_KEY=replace_with_youversion_key
YOUTUBE_API_KEY=replace_with_youtube_data_api_v3_key
CHAPTER_CACHE_TTL_SECONDS=3600
LOG_LEVEL=info

# Optional — server starts without these; features degrade gracefully
# REDIS_URL: leave empty for local dev; rate-limiting falls back to in-memory
# SMTP: all five must be set for password reset OTP emails to work
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# YTDLP_PROXY_URL: routes yt-dlp's YouTube requests through a proxy — needed
# on hosts like Render whose datacenter IPs YouTube blocks/rate-limits for
# audio-URL extraction. A residential/rotating proxy avoids that. Leave
# empty for local dev (usually unaffected). Format:
#   http://user:pass@proxy-host:port  or  socks5://user:pass@proxy-host:port
YTDLP_PROXY_URL=
